{
  "name": "@x402-paywall/agentkit-plugin",
  "version": "0.1.0",
  "description": "AgentKit-compatible plugin for x402 paywall — lets AI agents discover and pay for APIs via x402",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@x402-paywall/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
