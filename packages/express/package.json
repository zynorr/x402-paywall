{
  "name": "@x402-paywall/express",
  "version": "0.1.0",
  "description": "Express.js middleware for x402 paywall — one line to paywall any route",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@x402-paywall/core": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "express": "^4.18.0",
    "typescript": "^5.4.0"
  }
}
