{
  "name": "@x402-paywall/demo",
  "private": true,
  "version": "0.1.0",
  "description": "Demo app showcasing the x402 paywall middleware in action",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p server/tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist server/dist"
  },
  "dependencies": {
    "@x402-paywall/core": "workspace:*",
    "@x402-paywall/express": "workspace:*",
    "@x402-paywall/react": "workspace:*",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}
